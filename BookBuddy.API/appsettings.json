{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  // here will add our connection string section after Logging

  "ConnectionStrings": {

    // Syntax >>  "YOUR-CONNECTION-STRING NAME": "Server=YOUR_SERVER-NAME;Database=YOUR-DATABASE-NAME;Trusted_Connection=true;TrustServerCertificate=true;"
    "BookBuddyConnectionString": "Server=localhost;Database=BookBuddyDB;Trusted_Connection=true;TrustServerCertificate=true"
  },

  "Jwt": {
    "Key": "ThisIsMySuperSecretKeyForBookBuddy2026", //Used to digitally sign the JWT token
    "Issuer": "BookBuddyAPI", //Who created the token ,(BookBuddyAPI): null,
    "Audience": "BookBuddyUsers" // Who the token is intended for, (BookBuddyUsers)
    //The API will later validate all three.

  },

  "RentalSettings": {
    "RentalExpiryHours": 3
  },

  "Razorpay": {
    "KeyId": "YOUR_RAZORPAY_KEY_ID",
    "KeySecret": "YOUR RAZORPAY_KEYSECRET"
  },





  "AllowedHosts": "*"
}
